doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title Table Data

    // Bootstrap CSS
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      body {
        background: linear-gradient(to right, #f8fafc, #e2e8f0);
      }

      .orange {
        color: #f58220;
      }

      .link-orange {
        color: #f58220 !important;
        text-decoration: none;
      }

      .login-card {
        border-radius: 20px;
      }

      .form-control {
        border-radius: 10px;
        padding: 10px;
      }

      .form-control:focus {
        
        border-color: #f58220;
      }

      .btn-warning {
        background-color: #f58220 !important;
        border: none;
      }

      .btn-warning:hover {
        background-color: #f58220 !important;
      }

  body
    // ================= NAVBAR =================
    nav.navbar.navbar-expand-lg.bg-white.shadow-sm
      .container-fluid

        a.navbar-brand.fw-bold(style='color:#272b30;' href='/login') Best Shoppers

        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            
            li.nav-item
              a.nav-link(style='color:#272b30;' href="/login") Landing Page
            li.nav-item
              a.nav-link(style='color:#272b30;' href="/tableData") Table Data
            li.nav-item
              a.nav-link(style='color:#272b30;' href="/dashboard") Dashboard
            
    .container.min-vh-100.d-flex.align-items-center.justify-content-center
      .row.shadow-lg.bg-white.overflow-hidden(style='max-width: 850px; width:100%; border-radius:20px;')

        // LEFT SIDE (branding / info)
        .col-md-5.d-none.d-md-flex.flex-column.justify-content-center.align-items-center.text-center.p-4(style='background-color:#f58220; color:white;')
          
          h4.mt-3.fw-bold Table Data
          p.small.mt-2
            | Recent details of the data run in the course of businness.

        // RIGHT SIDE (form)
        .col-md-7.p-4.p-md-5
          form(method='post' action='/add-tableData')
            .mb-4
              label.form-label.fw-semibold(for='id') ID
              input#id.form-control(type='number' name='id')

              label.form-label.fw-semibold.mt-3(for='name') NAME
              input#name.form-control(type='text' name='name')

              label.form-label.fw-semibold.mt-3(for='category') CATEGORY
              input#category.form-control(type='text' name='category')

              label.form-label.fw-semibold.mt-3(for='price') PRICE
              input#price.form-control(type='number' name='price')

              label.form-label.fw-semibold.mt-3(for='quantity') QUANTITY
              input#quantity.form-control(type='number' name='quantity')

            button.btn.w-100.py-2.fw-bold.rounded-3(
              type='submit'
              style='background-color: #f58220; border: none;'
            ) Add Table Data
    // FOOTER
    footer.text-center.py-3.mt-4(style='position:absolute; bottom:10px; width:100%; color:#272b30;')
      small © Parvin 2026 Online Shopping System

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')